NODE_ENV=development
PORT=4000

# MongoDB - requires a single-node replica set (see docker-compose.yml at repo root)
MONGODB_URI=mongodb://localhost:27017/commerce-platform?replicaSet=rs0

# JWT
JWT_ACCESS_SECRET=changeme-access-secret
JWT_REFRESH_SECRET=changeme-refresh-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Stripe (test mode)
STRIPE_SECRET_KEY=sk_test_changeme
STRIPE_WEBHOOK_SECRET=whsec_changeme

# CORS
FRONTEND_URL=http://localhost:3000
